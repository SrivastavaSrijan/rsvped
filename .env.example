# Database Configuration
# Local Development
DATABASE_URL="postgresql://postgres:password@localhost:5432/rsvped"

# Production (Vercel Postgres or external PostgreSQL)
# DATABASE_URL="postgres://username:password@host:port/database?sslmode=require"

# NextAuth.js
AUTH_SECRET="your-super-secret-auth-secret" # openssl rand -hex 32
AUTH_URL="http://localhost:3000"

# Google OAuth (optional - leave empty if not using Google login)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App Configuration
NODE_ENV="development"

# Vercel Cron (used by /api/cron/reset-demo)
CRON_SECRET="" # openssl rand -hex 32

# Anthropic AI (Claude — used for WritingAssistant and AI Discovery)
ANTHROPIC_API_KEY=""

# Sentry (error tracking — leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

SECRET_COOKIE_PASSWORD="a-very-secure-password" # openssl rand -hex 32

# Seed System Configuration
# Customize these for your seeding needs

# Seed Data Volume
NUM_USERS=300
NUM_COMMUNITIES=50
EXTRA_STANDALONE_EVENTS=100
MIN_EVENTS_PER_CITY=15

# Feature Flags
USE_LLM=true
USE_BATCH_LOADER=true
SHOULD_WIPE=false

# Logging (debug, info, warn, error)
LOG_LEVEL=info

# Performance
MAX_CONCURRENT_OPERATIONS=10
BATCH_SIZE=100

# External APIs (optional)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_COLLECTION_ID=j7hIPPKdCOU
