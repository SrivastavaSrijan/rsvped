	"simple-git-hooks": {
		"pre-commit": "./.githooks/pre-commit"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"biome check --write",
			"biome format --write",
			"bash -c 'yarn type-check'"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "~2.1.1",
		"@faker-js/faker": "^9.9.0",
		"@playwright/test": "^1.59.1",
