		"embla-carousel-react": "^8.6.0",
		"es-toolkit": "^1.39.8",
		"iron-session": "^8.0.4",
		"lucide-react": "^0.525.0",
		"motion": "^12.38.0",
		"nanoid": "^5.1.5",
		"next": ">=15.5.3 <16",
		"next-auth": "^5.0.0-beta.29",
		"next-themes": "^0.4.6",
		"nodemailer": "^7.0.5",
		"prisma": "~6.11.1",
		"radix-ui": "^1.4.3",
		"react": "19.1.0",
		"react-day-picker": "^9.8.1",
		"react-dom": "19.1.0",
		"react-hook-form": "^7.60.0",
		"recharts": "^3.8.1",
		"sonner": "^2.0.6",
		"superjson": "^2.2.2",
