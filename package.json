		"@assistant-ui/react-ai-sdk": "^1.3.18",
		"@assistant-ui/react-markdown": "^0.12.8",
		"@auth/prisma-adapter": "^2.10.0",
		"@bprogress/next": "^3.2.12",
		"@hookform/resolvers": "^5.1.1",
		"@prisma/client": "~6.11.1",
		"@trpc/server": "^11.4.3",
		"ai": "^6.0.146",
		"bcryptjs": "^3.0.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dayjs": "^1.11.13",
